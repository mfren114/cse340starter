<h1>Add New Classification</h1>

<% messages() %>
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form id="classInventory" action="/inv/add-classification" method="post">
    <fieldset class="className-container">
        <label>Classification Name</label>
        <input type="text" id="className" pattern="[a-zA-Z0-9]+" title="No spaces or special characters">
        <span class="classNotice">Classification name cannot contain spaces or special characters</span>
        <button type="submit">Add Classification</button>
    </fieldset>
</form>