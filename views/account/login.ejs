<h1>Login</h1>
<%- messages() %>
<form action="login">
    <div>
        <label for="email">Email</label>
        <input type="text" email="email" id="email">
    </div>
    <div>
        <label for="pwd">Password</label>
        <input type="password" name="password" id="pwd">
    </div>
    <div>
        <button type="submit">Log In</button>
    </div>
    <p>No Account? <a href="">Sign Up Here</a></p>
</form>